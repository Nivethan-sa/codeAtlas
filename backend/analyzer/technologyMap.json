{
  "languages": {
    "javascript": {
      "extensions": [
        ".js",
        ".jsx",
        ".ts",
        ".tsx"
      ],
      "manifests": [
        "package.json"
      ],
      "importPattern": "(?:^\\s*import.*from\\s+['\"]([\\w\\.\\-\\/@]+)['\"]|require\\(['\"]([\\w\\.\\-\\/@]+)['\"]\\))",
      "classPattern": "class\\s+([a-zA-Z0-9_]+)",
      "functionPattern": "(?:function\\s+([a-zA-Z0-9_]+)\\s*\\(|const\\s+([a-zA-Z0-9_]+)\\s*=\\s*(?:async\\s*)?(?:\\([^)]*\\)|[a-zA-Z0-9_]+)\\s*=>)"
    },
    "python": {
      "extensions": [
        ".py"
      ],
      "manifests": [
        "requirements.txt",
        "Pipfile",
        "pyproject.toml"
      ],
      "importPattern": "^\\s*(?:import\\s+([\\w\\, ]+)|from\\s+([\\w\\.]+)\\s+import)",
      "classPattern": "class\\s+([a-zA-Z0-9_]+)\\s*[:\\(]",
      "functionPattern": "def\\s+([a-zA-Z0-9_]+)\\s*\\("
    },
    "go": {
      "extensions": [
        ".go"
      ],
      "manifests": [
        "go.mod"
      ],
      "importPattern": "^\\s*(?:import\\s+\"?([\\w\\.\\-\\/]+)\"?|\\s*\"([\\w\\.\\-\\/]+)\")",
      "classPattern": "type\\s+([a-zA-Z0-9_]+)\\s+struct",
      "functionPattern": "func\\s+(?:\\([^)]+\\)\\s+)?([a-zA-Z0-9_]+)\\s*\\("
    },
    "rust": {
      "extensions": [
        ".rs"
      ],
      "manifests": [
        "Cargo.toml"
      ],
      "importPattern": "^\\s*(?:use\\s+([\\w\\:]+)|extern\\s+crate\\s+(\\w+))",
      "classPattern": "(?:struct|trait)\\s+([a-zA-Z0-9_]+)",
      "functionPattern": "fn\\s+([a-zA-Z0-9_]+)\\s*\\("
    },
    "java": {
      "extensions": [
        ".java"
      ],
      "manifests": [
        "pom.xml",
        "build.gradle"
      ],
      "importPattern": "^\\s*import\\s+([\\w\\.]+);",
      "classPattern": "(?:public|private|protected)?\\s*(?:abstract|final)?\\s*class\\s+([a-zA-Z0-9_]+)",
      "functionPattern": "(?:public|private|protected)\\s+(?:static\\s+)?[\\w\\<\\>\\[\\]]+\\s+([a-zA-Z0-9_]+)\\s*\\("
    },
    "ruby": {
      "extensions": [
        ".rb"
      ],
      "manifests": [
        "Gemfile"
      ],
      "importPattern": "^\\s*(?:require|load)\\s+['\"]([\\w\\-\\/]+)['\"]",
      "classPattern": "class\\s+([a-zA-Z0-9_]+)",
      "functionPattern": "def\\s+([a-zA-Z0-9_]+)"
    },
    "php": {
      "extensions": [
        ".php"
      ],
      "manifests": [
        "composer.json"
      ],
      "importPattern": "^\\s*use\\s+([\\w\\\\]+);",
      "classPattern": "class\\s+([a-zA-Z0-9_]+)",
      "functionPattern": "function\\s+([a-zA-Z0-9_]+)\\s*\\("
    }
  },
