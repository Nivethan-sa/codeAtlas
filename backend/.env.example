# Copy this file to .env and fill in your own values.
# NEVER commit the real .env file - it's already in .gitignore.

# --- Database ------------------------------------------------------------
# Default: local SQLite file (created automatically on first run,
# nothing to install). Change this if you want the file somewhere else.
DB_PATH=./db/data/codeatlas.db

# --- Auth ------------------------------------------------------------------
# Any long random string. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="replace-this-with-a-long-random-string"

# --- GitHub API --------------------------------------------------------------
# Optional but recommended: raises the GitHub API rate limit from 60/hr
# to 5,000/hr. Create a fine-grained personal access token (no scopes
# needed for public repos) at https://github.com/settings/tokens
GITHUB_TOKEN=

# --- Server ------------------------------------------------------------------
PORT=5001
NODE_ENV=development
